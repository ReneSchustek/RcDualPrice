{
  "name": "ruhrcoder/rc-dual-price",
  "description": "Zeigt zweiten Preis (Netto oder Brutto) bei aktivierter Kategorieoption.",
  "type": "shopware-platform-plugin",
  "version": "1.2.0",
  "license": "MIT",
  "authors": [
    {
      "name": "Ruhrcoder (René Schustek)",
      "role": "Developer"
    }
  ],
  "require": {
    "shopware/core": "~6.7.0 || ~6.8.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5 || ^11.0",
    "phpstan/phpstan": "^2.0",
    "friendsofphp/php-cs-fixer": "^3.0"
  },
  "scripts": {
    "cs-check": "php-cs-fixer fix --dry-run --diff",
    "cs-fix": "php-cs-fixer fix",
    "phpstan": "phpstan analyse",
    "test": "phpunit --colors=always",
    "quality": [
      "@cs-check",
      "@phpstan",
      "@test"
    ]
  },
  "autoload": {
    "psr-4": {
      "Ruhrcoder\\RcDualPrice\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Ruhrcoder\\RcDualPrice\\Tests\\": "tests/"
    }
  },
  "extra": {
    "shopware-plugin-class": "Ruhrcoder\\RcDualPrice\\RcDualPrice",
    "label": {
      "de-DE": "Zweitpreis (Netto/Brutto)",
      "en-GB": "Dual Price (Net/Gross)"
    }
  }
}

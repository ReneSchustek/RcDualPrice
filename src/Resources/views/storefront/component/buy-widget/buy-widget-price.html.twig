{% sw_extends '@Storefront/storefront/component/buy-widget/buy-widget-price.html.twig' %}

{# Zweitpreis auf der Produktdetailseite (Einzelpreis + UVP) #}
{% block buy_widget_price_content %}
    {{ parent() }}

    {# Steuersatz aus dem tatsaechlich angewandten `calculatedTaxes` lesen, NICHT aus `product.tax.taxRate`
       (dem Basissatz der Steuergruppe) -- sonst falsch bei laenderabhaengigen Steuerregeln und in
       steuerfreien Kontexten. Analog zum bereits korrekten Line-Item-Pfad. `price` ist hier in Scope
       (vom aeusseren Core-Block gesetzt, wird unten fuer price.unitPrice ohnehin genutzt). #}
    {% set dualTax = price.calculatedTaxes.first %}
    {% set dualTaxRate = dualTax ? dualTax.taxRate : null %}

    {# `isListPrice`/`listPrice` setzt der Core per {% set %} INNERHALB von buy_widget_price_content --
       diese Variablen leaken nicht ueber {{ parent() }} in den ueberschreibenden Block. Deshalb hier
       aus dem verfuegbaren `price` ableiten, sonst rendert der durchgestrichene UVP-Zweitpreis nie. #}
    {% set dualIsListPrice = price.listPrice and price.listPrice.percentage > 0 %}

    {% if product.extensions.rc_dual_price_active.enabled and product.calculatedPrice and dualTaxRate is not null and dualTaxRate != 0 %}
        <div class="rc-dual-price" style="{{ product.extensions.rc_dual_price_active.cssStyles }}">
            {# UVP-Zweitpreis (durchgestrichen) wenn Listenpreis vorhanden #}
            {% if dualIsListPrice %}
                <s class="rc-dual-price-list-price">
                    {% sw_include '@RcDualPrice/storefront/component/rc-dual-price-label.html.twig' with {
                        unitPrice: price.listPrice.price,
                        taxRate: dualTaxRate,
                        taxState: context.taxState,
                        currencyIsoCode: currencyIsoCode
                    } only %}
                </s>
            {% endif %}

            {# Zweitpreis für den aktuellen Verkaufspreis #}
            {% sw_include '@RcDualPrice/storefront/component/rc-dual-price-label.html.twig' with {
                unitPrice: price.unitPrice,
                taxRate: dualTaxRate,
                taxState: context.taxState,
                currencyIsoCode: currencyIsoCode
            } only %}
        </div>
    {% endif %}
{% endblock %}

{# Staffelpreise: Tabellenüberschrift um Zweitpreis-Spalte erweitern.
   Kein {{ parent() }}: Der Core-Block ist EINE <tr> mit fixen <th>; die Zweitpreis-Spalte muss MITTEN
   in die Zeile (zwischen Preis und Referenzpreis). Ein parent()-Aufruf wuerde die komplette Core-Zeile
   davor ausgeben und liesse sich nicht aufbrechen -- daher wird die Zeile bewusst nachgebaut. Bei einer
   kuenftigen Core-Aenderung an den Kopf-Spalten ist dieser Block entsprechend nachzuziehen. #}
{% block buy_widget_price_block_table_head_inner %}
    <tr class="product-block-prices-row">
        <th scope="col" class="product-block-prices-cell">
            {{ 'detail.dataColumnQuantity'|trans|sw_sanitize }}
        </th>
        <th scope="col" class="product-block-prices-cell">
            {{ 'detail.dataColumnPrice'|trans|sw_sanitize }}
        </th>
        {% set headTax = product.calculatedPrice.calculatedTaxes.first %}
        {% if product.extensions.rc_dual_price_active.enabled and headTax and headTax.taxRate != 0 %}
            <th scope="col" class="product-block-prices-cell">
                {% if context.taxState == 'gross' %}
                    {{ "rc-dual-price.labelNet"|trans }}
                {% else %}
                    {{ "rc-dual-price.labelGross"|trans }}
                {% endif %}
            </th>
        {% endif %}
        {% if product.calculatedPrice.referencePrice %}
            <th scope="col" class="product-block-prices-cell">
                {{ 'detail.dataColumnReferencePrice'|trans|sw_sanitize }}
            </th>
        {% endif %}
    </tr>
{% endblock %}

{# Staffelpreise: Jede Tabellenzeile um Zweitpreis-Spalte erweitern #}
{% block buy_widget_price_block_table_body_cell_price %}
    <td class="product-block-prices-cell">
        {% sw_include '@Storefront/storefront/component/product/block-price.html.twig' with {
            price: price
        } only %}
    </td>

    {# Steuersatz je Staffel aus deren eigenem calculatedTaxes (nicht dem Basissatz). #}
    {% set tierTax = price.calculatedTaxes.first %}
    {% if product.extensions.rc_dual_price_active.enabled and tierTax and tierTax.taxRate != 0 %}
        <td class="product-block-prices-cell">
            {% sw_include '@RcDualPrice/storefront/component/rc-dual-price-label.html.twig' with {
                unitPrice: price.unitPrice,
                taxRate: tierTax.taxRate,
                taxState: context.taxState,
                currencyIsoCode: currencyIsoCode,
                hideLabel: true
            } only %}
        </td>
    {% endif %}
{% endblock %}

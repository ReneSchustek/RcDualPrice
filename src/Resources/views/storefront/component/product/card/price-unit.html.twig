{% sw_extends '@Storefront/storefront/component/product/card/price-unit.html.twig' %}

{# Zweitpreis in allen Produkt-Box-Varianten (Standard, Image, Minimal, Wishlist) #}
{% block component_product_box_price %}
    {{ parent() }}

    {# Steuersatz aus dem angewandten `calculatedTaxes` statt `product.tax.taxRate` (Basissatz) --
       korrekt bei Steuerregeln/steuerfreien Kontexten. `real` ist hier in Scope (aeusserer Core-Block),
       wird unten fuer real.unitPrice ohnehin genutzt. #}
    {% set dualTax = real.calculatedTaxes.first %}
    {% set dualTaxRate = dualTax ? dualTax.taxRate : null %}

    {# `isListPrice`/`price` setzt der Core per {% set %} INNERHALB dieses Blocks und leakt nicht ueber
       {{ parent() }} in den Override. Aus dem verfuegbaren `real` ableiten, sonst rendert der UVP nie. #}
    {% set dualIsListPrice = real.listPrice and real.listPrice.percentage > 0 %}

    {% if product.extensions.rc_dual_price_active.enabled and dualTaxRate is not null and dualTaxRate != 0 %}
        <div class="rc-dual-price" style="{{ product.extensions.rc_dual_price_active.cssStyles }}">
            {# UVP-Zweitpreis (durchgestrichen) wenn Listenpreis vorhanden #}
            {% if dualIsListPrice and not (displayFrom is defined and displayFrom) and not (displayFromVariants is defined and displayFromVariants) %}
                <s class="rc-dual-price-list-price">
                    {% sw_include '@RcDualPrice/storefront/component/rc-dual-price-label.html.twig' with {
                        unitPrice: real.listPrice.price,
                        taxRate: dualTaxRate,
                        taxState: context.taxState,
                        currencyIsoCode: currencyIsoCode
                    } only %}
                </s>
            {% endif %}

            {# "Ab"-Prefix bei Staffel-/Variantenpreisen #}
            {% if (displayFrom is defined and displayFrom) or (displayParent is defined and displayParent and hasDifferentPrice is defined and hasDifferentPrice and hasRange is defined and hasRange and totalVariants is defined and totalVariants|length > 1) %}
                {{ "rc-dual-price.labelFrom"|trans }}
            {% endif %}

            {# Zweitpreis für den aktuellen Verkaufspreis #}
            {% sw_include '@RcDualPrice/storefront/component/rc-dual-price-label.html.twig' with {
                unitPrice: real.unitPrice,
                taxRate: dualTaxRate,
                taxState: context.taxState,
                currencyIsoCode: currencyIsoCode
            } only %}
        </div>
    {% endif %}
{% endblock %}

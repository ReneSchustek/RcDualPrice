<?xml version="1.0" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="
           http://symfony.com/schema/dic/services
           http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <defaults autowire="false" autoconfigure="false"/>

        <service id="Ruhrcoder\RcDualPrice\Service\ConfigService">
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
        </service>

        <service id="Ruhrcoder\RcDualPrice\Service\CategoryDualPriceHelper"/>

        <service id="Ruhrcoder\RcDualPrice\Twig\DualPriceTwigExtension">
            <tag name="twig.extension"/>
            <argument type="service" id="Ruhrcoder\RcDualPrice\Service\ConfigService"/>
        </service>

        <service id="Ruhrcoder\RcDualPrice\Subscriber\CriteriaSubscriber">
            <tag name="kernel.event_subscriber"/>
            <argument type="service" id="Ruhrcoder\RcDualPrice\Service\ConfigService"/>
        </service>

        <service id="Ruhrcoder\RcDualPrice\Subscriber\PageSubscriber">
            <tag name="kernel.event_subscriber"/>
            <argument type="service" id="Ruhrcoder\RcDualPrice\Service\ConfigService"/>
            <argument type="service" id="Ruhrcoder\RcDualPrice\Service\CategoryDualPriceHelper"/>
        </service>
    </services>
</container>
